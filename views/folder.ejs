<%- include("partials/header", { title: folder.name }) %>

<h1><%= folder.name %></h1>

<p>
    <a href="/dashboard">Dashboard</a>

    <% breadcrumbs.forEach(crumb => { %>
        /
        <a href="/folders/<%= crumb.id %>">
            <%= crumb.name %>
        </a>
    <% }) %>
</p>

<p>Created: <%= folder.createdAt.toLocaleDateString() %></p><h2>Child Folders</h2>

<% if (folder.children.length > 0) { %>
    <ul>
        <% folder.children.forEach(child => { %>
            <li>
                <a href="/folders/<%= child.id %>">
                    <%= child.name %>
                </a>
            </li>
        <% }) %>
    </ul>
<% } else { %>
    <p>No child folders yet.</p>
<% } %>


<form action="/folders" method="POST">
    <% if (formType === "childFolder") { %>
        <%- include("partials/error") %>
    <% } %>
    <h2>Create Child Folder</h2>
    <%
    const childFolderNameError =
        formType === "childFolder"
            ? errors.find(error => error.path === "name")
            : null;
    %>
    <input type="hidden" name="parentId" value="<%= folder.id %>">
    <div>
        <label for="child-name">Folder Name:</label>
        <input type="text" id="child-name" name="name" value="<%= formType === 'childFolder' ? (data.name || '') : '' %>" class="<%= childFolderNameError ? 'input-error' : '' %>" required>
    </div>
    <button type="submit">Create Child Folder</button>
</form>

<h2>Files</h2>

<% if (folder.files.length > 0) { %>
    <ul>
        <% folder.files.forEach(file => { %>
            <li>
                <strong><%= file.name %></strong>

                <ul>
                    <li>Type: <%= file.mimeType %></li>
                    <li>Size: <%= file.formattedSize %></li>
                    <li>Uploaded: <%= file.uploadedAt.toLocaleString() %></li>
                    <li>
                        <a href="/folders/files/<%= file.id %>/download">
                            Download
                        </a>
                    </li>
                    <li>
                        <form action="/folders/files/<%= file.id %>/delete" method="POST">
                            <button type="submit">Delete</button>
                        </form>
                    </li>
                </ul>
            </li>
        <% }) %>
    </ul>
<% } else { %>
    <p>No files uploaded yet.</p>
<% } %>

<form action="/folders/<%= folder.id %>/files" method="POST" enctype="multipart/form-data">
    <h2>Upload File</h2>

    <% if (formType === "upload") { %>
        <%- include("partials/error") %>
    <% } %>

    <div>
        <label for="file">Choose File:</label>
        <input type="file" id="file" name="file" required>
    </div>

    <p>
        Allowed types: JPG, PNG, WEBP, PDF, TXT.
        Maximum size: 10 MB.
    </p>

    <button type="submit">Upload</button>
</form>


<form action="/folders/<%= folder.id %>/edit" method="POST">
    <% if (formType === "rename") { %>
        <%- include("partials/error") %>
    <% } %>

    <% const renameNameError = formType === "rename" ? errors.find(error => error.path === "name") : null; %>
    <div>
        <label for="name">Rename Folder:</label>
        <input type="text" id="name" name="name" value="<%= formType === 'rename' ? (data.name || '') : folder.name%>" class="<%= renameNameError ? 'input-error' : '' %>" required>
    </div>
    <button type="submit">Rename</button>
</form>

<form action="/folders/<%= folder.id %>/delete" method="POST">
    <button type="submit">Delete Folder</button>
</form>

<%- include("partials/footer") %>