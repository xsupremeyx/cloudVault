<%- include("partials/header", { title: "Log In — CloudVault" }) %>
<main class="main-content">
  <div class="container">
    <div class="card card-auth">
      <!-- Card header -->
      <div class="card-header" style="flex-direction: column; align-items: flex-start; gap: var(--space-1);">
        <div style="
          width: 40px;
          height: 40px;
          background-color: var(--color-accent-subtle);
          border-radius: var(--radius-lg);
          display: flex;
          align-items: center;
          justify-content: center;
          margin-bottom: var(--space-3);
        ">
          <i data-lucide="log-in" style="width:20px;height:20px;color:var(--color-accent);" aria-hidden="true"></i>
        </div>
        <h1 class="card-title" style="font-size: var(--text-2xl);">Welcome back</h1>
        <p class="card-subtitle">Sign in to access your CloudVault.</p>
      </div>
      <!-- Validation errors -->
      <%- include("partials/error") %>
      <!-- Log-in form — action, method, and all name attributes are frozen -->
      <form action="/log-in" method="POST" novalidate>
        <%
          const usernameError = errors.find(e => e.path === "username");
          const passwordError = errors.find(e => e.path === "password");
        %>
        <div class="form-group">
          <label for="username">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            value="<%= data.username || '' %>"
            class="<%= usernameError ? 'input-error' : '' %>"
            placeholder="Your username"
            autocomplete="username"
            required
          >
          <% if (usernameError) { %>
            <span class="field-error"><%= usernameError.msg %></span>
          <% } %>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="<%= passwordError ? 'input-error' : '' %>"
            placeholder="Your password"
            autocomplete="current-password"
            required
          >
          <% if (passwordError) { %>
            <span class="field-error"><%= passwordError.msg %></span>
          <% } %>
        </div>
        <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top: var(--space-2);">
          <i data-lucide="arrow-right" style="width:16px;height:16px;" aria-hidden="true"></i>
          Log In
        </button>
      </form>
      <!-- Footer link -->
      <div class="card-footer" style="justify-content: center; border-top: 1px solid var(--color-border);">
        <p style="font-size: var(--text-sm); color: var(--color-text-muted); max-width: none; margin: 0;">
          Don't have an account?&nbsp;<a href="/sign-up">Sign Up</a>
        </p>
      </div>
    </div>
  </div>
</main>
<%- include("partials/footer") %>