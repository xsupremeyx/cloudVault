<%- include("partials/header", { title: "Error — CloudVault" }) %>
<main class="main-content">
  <div class="container" style="
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - var(--navbar-height) - 160px);
    gap: var(--space-4);
  ">
    <% if (status === 404) { %>
      <h1 style="
        font-size: clamp(var(--text-4xl), 18vw, 8rem);
        font-weight: var(--font-bold);
        color: var(--color-text-muted);
        line-height: 1;
        letter-spacing: -0.04em;
      ">404</h1>
      <h2 style="font-size: var(--text-2xl); margin-top: var(--space-2);">Page not found</h2>
      <p style="color: var(--color-text-secondary); max-width: 40ch; font-size: var(--text-base);">
        The page you're looking for doesn't exist or may have been moved.
      </p>
    <% } else if (status === 410) { %>
      <h1 style="
        font-size: clamp(var(--text-4xl), 18vw, 8rem);
        font-weight: var(--font-bold);
        color: var(--color-text-muted);
        line-height: 1;
        letter-spacing: -0.04em;
      ">410</h1>
      <h2 style="font-size: var(--text-2xl); margin-top: var(--space-2);">Link expired</h2>
      <p style="color: var(--color-text-secondary); max-width: 40ch; font-size: var(--text-base);">
        This share link has expired or been removed. Ask the owner for a new one.
      </p>
    <% } else { %>
      <h1 style="
        font-size: clamp(var(--text-4xl), 18vw, 8rem);
        font-weight: var(--font-bold);
        color: var(--color-text-muted);
        line-height: 1;
        letter-spacing: -0.04em;
      ">500</h1>
      <h2 style="font-size: var(--text-2xl); margin-top: var(--space-2);">Something went wrong</h2>
      <p style="color: var(--color-text-secondary); max-width: 40ch; font-size: var(--text-base);">
        An unexpected error occurred on our end. Please try again in a moment.
      </p>
    <% } %>
    <a href="/" class="btn btn-primary" style="margin-top: var(--space-4);">
      <i data-lucide="arrow-left" style="width:15px;height:15px;" aria-hidden="true"></i>
      Go Home
    </a>
  </div>
</main>
<%- include("partials/footer") %>