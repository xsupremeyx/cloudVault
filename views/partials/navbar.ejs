<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="container navbar__inner">
    <!-- ── Brand / Logo ── -->
    <a href="/" class="navbar__brand" aria-label="CloudVault — go to home">
      <div class="navbar__brand-icon" aria-hidden="true">
        <i data-lucide="cloud" style="width:17px;height:17px;"></i>
      </div>
      <span class="navbar__brand-name">Cloud<span class="accent">Vault</span></span>
    </a>
    <!-- ── Right-side controls ── -->
    <div class="navbar__nav" role="list">
      <% if (currentUser) { %>
        <!-- User identity -->
        <div class="navbar__user" role="listitem">
          <div class="navbar__avatar" aria-hidden="true" title="<%= currentUser.username %>">
            <%= currentUser.username.charAt(0).toUpperCase() %>
          </div>
          <span class="navbar__username-text"><%= currentUser.username %></span>
        </div>
        <div class="navbar__divider" aria-hidden="true"></div>
        <!-- Dashboard link -->
        <a href="/dashboard" class="navbar__link" role="listitem">
          <i data-lucide="layout-dashboard" style="width:14px;height:14px;" aria-hidden="true"></i>
          Dashboard
        </a>
        <!-- Log Out — must remain a POST form; GET /log-out does not exist -->
        <form action="/log-out" method="POST" class="navbar__logout-form" role="listitem">
          <button type="submit" class="btn btn-secondary btn-sm">
            <i data-lucide="log-out" style="width:13px;height:13px;" aria-hidden="true"></i>
            Log Out
          </button>
        </form>
      <% } else { %>
        <a href="/log-in"  class="navbar__link" role="listitem">Log In</a>
        <a href="/sign-up" class="btn btn-primary btn-sm" role="listitem">Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>