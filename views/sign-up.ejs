<%- include("partials/header", { title: "Sign Up — CloudVault" }) %>
<main class="main-content">
  <div class="container">
    <div class="card card-auth">
      <!-- Card header -->
      <div class="card-header" style="flex-direction: column; align-items: flex-start; gap: var(--space-1);">
        <div style="
          width: 40px;
          height: 40px;
          background-color: var(--color-accent-subtle);
          border-radius: var(--radius-lg);
          display: flex;
          align-items: center;
          justify-content: center;
          margin-bottom: var(--space-3);
        ">
          <i data-lucide="user-plus" style="width:20px;height:20px;color:var(--color-accent);" aria-hidden="true"></i>
        </div>
        <h1 class="card-title" style="font-size: var(--text-2xl);">Create an account</h1>
        <p class="card-subtitle">Join CloudVault and start storing your files.</p>
      </div>
      <!-- Validation errors -->
      <%- include("partials/error") %>
      <!-- Sign-up form — action, method, and all name attributes are frozen -->
      <form action="/sign-up" method="POST" novalidate>
        <%
          const usernameError      = errors.find(e => e.path === "username");
          const passwordError      = errors.find(e => e.path === "password");
          const confirmPasswordError = errors.find(e => e.path === "confirmPassword");
        %>
        <div class="form-group">
          <label for="username">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            value="<%= data.username || '' %>"
            class="<%= usernameError ? 'input-error' : '' %>"
            placeholder="Choose a username"
            autocomplete="username"
            required
          >
          <% if (usernameError) { %>
            <span class="field-error"><%= usernameError.msg %></span>
          <% } %>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="<%= passwordError ? 'input-error' : '' %>"
            placeholder="Create a password"
            autocomplete="new-password"
            required
          >
          <% if (passwordError) { %>
            <span class="field-error"><%= passwordError.msg %></span>
          <% } %>
        </div>
        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            class="<%= confirmPasswordError ? 'input-error' : '' %>"
            placeholder="Repeat your password"
            autocomplete="new-password"
            required
          >
          <% if (confirmPasswordError) { %>
            <span class="field-error"><%= confirmPasswordError.msg %></span>
          <% } %>
        </div>
        <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top: var(--space-2);">
          <i data-lucide="user-check" style="width:16px;height:16px;" aria-hidden="true"></i>
          Create Account
        </button>
      </form>
      <!-- Footer link -->
      <div class="card-footer" style="justify-content: center; border-top: 1px solid var(--color-border);">
        <p style="font-size: var(--text-sm); color: var(--color-text-muted); max-width: none; margin: 0;">
          Already have an account?&nbsp;<a href="/log-in">Log In</a>
        </p>
      </div>
    </div>
  </div>
</main>
<%- include("partials/footer") %>